// =================================================================
//  TYPES
// =================================================================
type ACItem = { label: string; code: string; type?: "airport" | "city"; bg?: string };
type FlightResult = {
  type: "flight" | "train" | "bus" | "ferry";
  price: number; airline?: string; transfers?: number;
  origin?: string; destination?: string;
  departure_date?: string; departure_time?: string;
  duration?: string; link: string;
};
type TwoWayData = {
  outbound: FlightResult[]; return: FlightResult[];
  outbound_count: number; return_count: number;
};
// Deal type imported from ./components/DestCards

// =================================================================
//  AUTOCOMPLETE HOOK — single setupAC behavior
// =================================================================
function useAutocomplete(type: "airport" | "city" | "flight") {
  const [items, setItems] = useState<ACItem[]>([]);
  const [open, setOpen] = useState(false);
  const timer = useRef<ReturnType<typeof setTimeout> | null>(null);

  const onChange = useCallback((q: string) => {
    if (timer.current) clearTimeout(timer.current);
    if (q.length < 2) { setOpen(false); return; }
    timer.current = setTimeout(async () => {
      try {
        if (type === "airport" || type === "flight") {
          const tpUrl = `https://autocomplete.travelpayouts.com/places2?term=${encodeURIComponent(q)}&locale=en&types[]=city&types[]=airport`;
          const tpRes = await fetch(tpUrl).then(r => r.json()).catch(() => []);
          const airports: ACItem[] = (tpRes as any[]).slice(0, 5)
            .filter(a => a.name?.toLowerCase().indexOf(q.toLowerCase()) === 0)
            .map(i => ({
              label: i.name + (i.country_name ? `, ${i.country_name}` : ""),
              code: i.code || "",
              type: "airport" as const,
            }));
          if (type === "flight") {
            // Also fetch cities (Photon) for non-airport rail destinations
            const phRes = await fetch(`https://photon.komoot.io/api/?q=${encodeURIComponent(q)}&limit=4&lang=en`)
              .then(r => r.json()).catch(() => ({ features: [] }));
            const airportNames = new Set(airports.map(a => a.label.split(",")[0].toLowerCase()));
            const cities: ACItem[] = ((phRes as any).features || [])
              .filter((f: any) => {
                const n = (f.properties?.name || "").toLowerCase();
                return n.indexOf(q.toLowerCase()) === 0 && !airportNames.has(n) && n.length > 1;
              })
              .slice(0, 3)
              .map((f: any) => ({
                label: f.properties.name + (f.properties.country ? `, ${f.properties.country}` : ""),
                code: f.properties.name || "",
                type: "city" as const,
                bg: "#FFF8F0",
              }));
            setItems([...airports, ...cities]);
          } else {
            setItems(airports);
          }
        } else {
          const phRes = await fetch(`https://photon.komoot.io/api/?q=${encodeURIComponent(q)}&limit=6&lang=en`)
            .then(r => r.json());
          const cities: ACItem[] = ((phRes as any).features || []).slice(0, 6).map((f: any) => ({
            label: f.properties.name + (f.properties.country ? `, ${f.properties.country}` : ""),
            code: f.properties.name || "",
            type: "city" as const,
          }));
          setItems(cities);
        }
        setOpen(true);
      } catch {
        setOpen(false);
      }
    }, 300);
  }, [type]);

  return { items, open, onChange, setOpen };
}

// =================================================================
//  AUTOCOMPLETE INPUT COMPONENT
// =================================================================
function ACInput(props: {
  id: string; label: string; placeholder: string;
  type: "airport" | "city" | "flight";
  value: string; code: string;
  onPick: (label: string, code: string) => void;
  onChange: (v: string) => void;
  onSwitchToTrains?: (from: string, to: string) => void;
}) {
  const { items, open, onChange, setOpen } = useAutocomplete(props.type);

  return (
    <div className="form-field">
      <label>{props.label}</label>
      <input
        id={props.id}
        type="text"
        autoComplete="off"
        placeholder={props.placeholder}
        value={props.value}
        onChange={e => { props.onChange(e.target.value); onChange(e.target.value); }}
        onBlur={() => setTimeout(() => setOpen(false), 200)}
        onFocus={() => { if (items.length > 0) setOpen(true); }}
      />
      <div className={"ac-dropdown" + (open ? " show" : "")}>
        {items.map((it, i) => (
          <div
            key={i}
            className="ac-opt"
            style={it.bg ? { background: it.bg } : undefined}
            onMouseDown={e => {
              e.preventDefault();
              if (it.type === "city" && props.type === "flight" && props.onSwitchToTrains) {
                props.onSwitchToTrains(props.value, it.label);
                setOpen(false);
                return;
              }
              props.onPick(it.label, it.code);
              setOpen(false);
            }}
          >
            <span>{it.label}</span>
            <span
              className="ac-code"
              style={it.type === "city" && props.type === "flight" ? { color: "#BA7517" } : undefined}
            >
              {it.type === "city" && props.type === "flight" ? "🚂 Trains →" : it.code}
            </span>
          </div>
        ))}
      </div>
    </div>
  );
}

// =================================================================
//  BRAND LOGO (V + oyage / GO)
// =================================================================
function BrandLogo() {
  return (
    <span className="brand-wrap">
      <span className="brand">
        <span className="v">V</span>
        <span className="stack">
          <span className="oyage">oyage</span>
          <span className="go">GO</span>
        </span>
      </span>
    </span>
  );
}

