// =================================================================
export default function Page() {
  const [lang, setLang] = useState("en");
  const [cur, setCur] = useState("EUR");
  const [curSym, setCurSym] = useState("€");
  const [tab, setTab] = useState<"flights" | "trains" | "buses" | "ferry" | "hotels" | "tours" | "cars">("flights");
  const [tripType, setTripType] = useState<"return" | "oneway">("return");

  // Form state per tab
  const [flFrom, setFlFrom] = useState(""); const [flFromCode, setFlFromCode] = useState("");
  const [flTo, setFlTo] = useState(""); const [flToCode, setFlToCode] = useState("");
  const [flDate, setFlDate] = useState(""); const [flReturn, setFlReturn] = useState("");

  const [htCity, setHtCity] = useState(""); const [, setHtCityCode] = useState("");
  const [htIn, setHtIn] = useState(""); const [htOut, setHtOut] = useState("");

  const [toCity, setToCity] = useState(""); const [, setToCityCode] = useState("");
  const [caCity, setCaCity] = useState(""); const [, setCaCityCode] = useState("");

  // UI state
  const [langModalOpen, setLangModalOpen] = useState(false);
  const [curModalOpen, setCurModalOpen] = useState(false);
  const [resultsOpen, setResultsOpen] = useState(false);
  const [resultsTitle, setResultsTitle] = useState("Results");
  const [resultsHTML, setResultsHTML] = useState("");
  const [stickyVisible, setStickyVisible] = useState(false);
  const [deals, setDeals] = useState<Deal[]>([]);

  const heroRef = useRef<HTMLElement>(null);

  // ---- scroll: sticky bar ----
  useEffect(() => {
    const onScroll = () => {
      if (!heroRef.current) return;
      const hb = heroRef.current.offsetHeight - 100;
      setStickyVisible(window.scrollY > hb);
    };
    window.addEventListener("scroll", onScroll, { passive: true });
    return () => window.removeEventListener("scroll", onScroll);
  }, []);

  // ---- body scroll lock when modal open ----
  useEffect(() => {
    document.body.style.overflow = resultsOpen ? "hidden" : "";
    return () => { document.body.style.overflow = ""; };
  }, [resultsOpen]);

  // ---- load deals when lang/cur changes ----
  const loadDeals = useCallback(async () => {
    try {
      const useAviasales = lang === "ru" || lang === "uk" || cur === "RUB";
      const r = await fetch(`${API_BASE}/api/deals?origin=LIS&lang=${useAviasales ? "ru" : lang}`);
      const data = await r.json();
      setDeals(data.deals || []);
    } catch { /* keep static cards */ }
  }, [lang, cur]);

  useEffect(() => { loadDeals(); }, [loadDeals]);

  // ---- Omio widget loader (one time) ----
  useEffect(() => {
    if ((window as any).__omioLoaded) return;
    (window as any).__omioLoaded = true;
    const v = Date.now();
    const link = document.createElement("link");
    link.rel = "stylesheet";
    link.href = `https://www.omio.com/gcs-proxy/b2b-nemo-prod/bundle/en/bundle.css?v=${v}`;
    document.head.appendChild(link);
    const s = document.createElement("script");
    s.src = `https://www.omio.com/gcs-proxy/b2b-nemo-prod/bundle/en/bundle.js?v=${v}`;
    document.body.appendChild(s);
  }, []);

  // =================================================================
  //  RESULT CARD BUILDER (mirrors original buildCard)
  // =================================================================
  const buildCard = (r: FlightResult): string => {
    let tag = "";
    if (r.type === "train") tag = '<span class="result-tag direct">Train</span>';
    else if (r.type === "bus") tag = '<span class="result-tag" style="background:#E8EAF6;color:#3949AB">Bus</span>';
    else if (r.type === "ferry") tag = '<span class="result-tag" style="background:#E0F7FA;color:#00838F">Ferry</span>';
    else if (r.transfers === 0) tag = '<span class="result-tag direct">Direct</span>';
    else tag = `<span class="result-tag stop">${r.transfers} stop</span>`;

    const safe = r.link.replace(/'/g, "%27").replace(/"/g, "&quot;");
    const priceHTML = r.type === "flight"
      ? `<div class="result-price">${curSym}${Math.round(r.price * RATES[cur])}</div>`
      : `<div class="result-price" style="font-size:15px">${curSym}${Math.round(r.price * RATES[cur])}–${curSym}${Math.round(r.price * 1.5 * RATES[cur])}</div>`;
    const route = r.type === "flight"
      ? `${r.origin || ""} → ${r.destination || ""}`
      : r.type.charAt(0).toUpperCase() + r.type.slice(1);

    let details = tag;
    if (r.airline) details += `<span>${airName(r.airline)}</span>`;
    if (r.departure_time) details += `<span>${r.departure_time}</span>`;
    if (r.duration) details += `<span>${r.duration}</span>`;

    return `<div class="result-card" data-link="${safe}">${priceHTML}<div class="result-info"><div class="result-route">${route}</div><div class="result-details">${details}</div></div><div class="result-arrow">›</div></div>`;
  };

  // delegate clicks on result cards
  useEffect(() => {
    const handler = (e: MouseEvent) => {
      const target = (e.target as HTMLElement).closest(".result-card") as HTMLElement | null;
      if (target?.dataset.link) window.open(target.dataset.link, "_blank");
    };
    document.addEventListener("click", handler);
    return () => document.removeEventListener("click", handler);
  }, []);

  // =================================================================
  //  RENDER TWO-WAY RESULTS
  // =================================================================
  const renderTwoWay = (data: TwoWayData, from: string, to: string) => {
    const noResults = !data.outbound.length && !data.return.length;
    const fcode = flFromCode || flFrom.slice(0, 3).toUpperCase();
    const tcode = flToCode || flTo.slice(0, 3).toUpperCase();
    const useAviasales = lang === "ru" || lang === "uk";

    let fallbackLink = `https://www.trip.com/flights/?dcity=${fcode}&acity=${tcode}&ddate=${flDate}&Allianceid=${P.trip.a}&SID=${P.trip.s}`;
    if (useAviasales) {
      const dd = flDate ? flDate.slice(8, 10) + flDate.slice(5, 7) : "";
      fallbackLink = `https://www.aviasales.ru/search/${fcode}${dd}${tcode}1?marker=${P.tp.marker}`;
    }
    const partner = useAviasales ? "Aviasales" : "Trip.com";

    if (noResults) {
      setResultsHTML(
        `<div class="result-empty" style="padding:30px;text-align:center"><p style="margin-bottom:16px">${t(lang, "no_results")}</p><a href="${fallbackLink}" target="_blank" style="display:inline-block;background:#1A2332;color:#fff;padding:12px 24px;border-radius:10px;text-decoration:none;font-weight:600">${t(lang, "search_on")} ${partner} →</a></div>`
      );
      return;
    }

    const resultsTo = TR[lang]?.results_to || "to";
    let h = "<div>";
    h += `<div style="padding:14px 22px;background:#F8F7F3;border-bottom:1px solid rgba(0,0,0,.06)"><div style="font-weight:600;font-size:14px">${from} ${resultsTo} ${to} — ${data.outbound_count} options</div><div style="font-size:12px;color:#888;margin-top:2px">${t(lang, "best_price")}</div></div>`;
    h += '<div class="results-list" style="max-height:40vh">';
    data.outbound.forEach(r => { h += buildCard(r); });
    if (!data.outbound.length) {
      h += `<div style="padding:20px;text-align:center"><a href="${fallbackLink}" target="_blank" style="display:inline-block;background:#1A2332;color:#fff;padding:12px 24px;border-radius:10px;text-decoration:none;font-weight:500">${t(lang, "outbound_no")} ${partner} →</a></div>`;
    }
    h += "</div>";
    if (data.return_count > 0) {
      h += `<div style="padding:14px 22px;background:#F8F7F3;border-bottom:1px solid rgba(0,0,0,.06);border-top:2px solid #1A2332"><div style="font-weight:600;font-size:14px">${to} ${resultsTo} ${from} — ${data.return_count} options</div></div>`;
      h += '<div class="results-list" style="max-height:40vh">';
      (data.return || []).forEach(r => { h += buildCard(r); });
      h += "</div>";
    }
    h += `<div style="padding:12px 22px;background:#F8F7F3;border-top:1px solid rgba(0,0,0,.06);font-size:11px;color:#888">${t(lang, "prices_approx")}</div></div>`;
    setResultsHTML(h);
  };

  // =================================================================
  //  SEARCH HANDLERS
  // =================================================================
  const searchFlights = async () => {
    if (!flFrom || !flTo) return;
    const fc = flFromCode || flFrom.slice(0, 3).toUpperCase();
    const tc = flToCode || flTo.slice(0, 3).toUpperCase();
    const rd = tripType === "oneway" ? "" : flReturn;
    setResultsTitle(`${flFrom} — ${flTo}`);
    setResultsHTML(`<div class="results-loading" style="padding:40px;text-align:center;color:#888">${lang === "ru" ? "Поиск..." : "Searching..."}</div>`);
    setResultsOpen(true);
    try {
      let url = `${API_BASE}/api/search-return?origin=${fc}&dest=${tc}&date=${flDate}&lang=${lang}`;
      if (rd) url += `&return_date=${rd}`;
      const res = await fetch(url);
      const data: TwoWayData = await res.json();
      renderTwoWay(data, flFrom, flTo);
    } catch {
      setResultsHTML('<div class="result-empty">Error. Try again.</div>');
    }
  };

  const searchHotels = () => {
    const c = htCity.split(",")[0].trim();
    if (!c) return;
    window.open(`https://search.hotellook.com/hotels?destination=${encodeURIComponent(c)}&checkIn=${htIn}&checkOut=${htOut}&currency=${cur.toLowerCase()}&marker=${P.tp.marker}`, "_blank");
  };

  const searchTours = () => {
    const c = toCity.split(",")[0].trim();
    if (!c) return;
    window.open(`https://www.getyourguide.com/s/?q=${encodeURIComponent(c)}&partner_id=${P.gyg.id}&utm_medium=online_publisher`, "_blank");
  };

  const searchCars = () => {
    const c = caCity.split(",")[0].trim().toLowerCase().replace(/ /g, "-");
    if (!c) return;
    window.open(`https://www.discovercars.com/${c}?a_aid=${P.dc.id}`, "_blank");
  };

  // helper for autocomplete city click in flights tab
  const switchToTrainsFromFlights = (from: string, to: string) => {
    setTab("trains");
    // Trains use Omio widget directly — we just switch the tab.
    // The Omio widget reads its own inputs; we still keep autocomplete as a hint.
  };

  // =================================================================
  //  RENDER
  // =================================================================
  return (
    <>
      <IconSprites />

      {/* Sticky bar — shown after scrolling past hero */}
      <div className={"sticky-bar" + (stickyVisible ? " visible" : "")}>
        <div className="logo">
          <BrandLogo />
        </div>
        <div className="summary">
          <svg className="icon" style={{ fontSize: 14 }}><use href="#i-search" /></svg>
          <span>Lisbon → Paris</span><span className="sep">·</span>
          <span>Jun 14 — Jun 21</span><span className="sep">·</span>
          <span>1 adult</span>
        </div>
        <button onClick={() => document.getElementById("fl-from")?.focus()}>
          {t(lang, "search")}
        </button>
      </div>

      {/* HERO */}
      <section className="hero" ref={heroRef as any}>
        <HeroSvg />
        <div className="hero-overlay" />

        <nav className="nav">
          <div className="logo"><BrandLogo /></div>
          <span className="hamburger" aria-label="Menu">
            <svg className="icon"><use href="#i-menu-2" /></svg>
          </span>
          <div className="nav-links">
            <a href="#destinations">{t(lang, "nav_dest")}</a>
            <a href="#how">{t(lang, "nav_how")}</a>
            <span className="lang-pill" onClick={() => setCurModalOpen(v => !v)} style={{ marginRight: 6 }}>
              <span>{curSym} {cur}</span>
            </span>
            <span className="lang-pill" onClick={() => setLangModalOpen(v => !v)}>
              <svg className="icon"><use href="#i-world" /></svg>
              <span>{lang.toUpperCase()}</span>
            </span>
            <a href="https://t.me/VoyageGoBot" target="_blank" rel="noreferrer" className="signin-btn">
              {t(lang, "tg_btn")}
            </a>
          </div>
        </nav>

        {/* Currency modal */}
        {curModalOpen && (
          <div
            className="lang-modal-bg show"
            onClick={e => { if (e.target === e.currentTarget) setCurModalOpen(false); }}
          >
            <div className="lang-modal-box">
              <h3>Currency</h3>
              <div className="lang-grid-items">
                {CURRENCIES.map(c => (
                  <div
                    key={c.c}
                    className={"lang-opt" + (c.c === cur ? " active" : "")}
                    onClick={() => { setCur(c.c); setCurSym(c.s); setCurModalOpen(false); }}
                  >
                    {c.s} {c.c}
                  </div>
                ))}
              </div>
            </div>
          </div>
        )}

        {/* Language modal */}
        {langModalOpen && (
          <div
            className="lang-modal-bg show"
            onClick={e => { if (e.target === e.currentTarget) setLangModalOpen(false); }}
          >
            <div className="lang-modal-box">
              <h3>Language</h3>
              <div className="lang-grid-items">
                {LANGS.map(l => (
                  <div
                    key={l.c}
                    className={"lang-opt" + (l.c === lang ? " active" : "")}
                    onClick={() => { setLang(l.c); setLangModalOpen(false); }}
                  >
                    {l.f} {l.n}
                  </div>
                ))}
              </div>
            </div>
          </div>
        )}

        <div className="hero-content">
          <h1 dangerouslySetInnerHTML={{ __html: t(lang, "hero_title") }} />
          <p>{t(lang, "hero_sub")}</p>
        </div>

        {/* SEARCH CARD */}
        <div className="search-card">
          <div className="tabs">
            {([
              ["flights", "i-plane", "tab_flights"],
              ["trains", "i-route", "tab_trains"],
              ["buses", "i-car", "tab_buses"],
              ["ferry", "i-route", "tab_ferry"],
              ["hotels", "i-bed", "tab_hotels"],
              ["tours", "i-map-pin", "tab_tours"],
              ["cars", "i-car", "tab_cars"],
            ] as const).map(([k, ic, tk]) => (
              <div
                key={k}
                className={"tab" + (tab === k ? " active" : "")}
                onClick={() => setTab(k as typeof tab)}
              >
                <svg className="icon"><use href={`#${ic}`} /></svg>
                <span>{t(lang, tk)}</span>
              </div>
            ))}
          </div>

          {/* FLIGHTS */}
          <div className={"tab-form" + (tab === "flights" ? " active" : "")}>
            <div style={{ display: "flex", gap: 8, marginBottom: 12 }}>
              <button
                className={"trip-toggle" + (tripType === "return" ? " active" : "")}
                onClick={() => setTripType("return")}
              >{t(lang, "return_btn")}</button>
              <button
                className={"trip-toggle" + (tripType === "oneway" ? " active" : "")}
                onClick={() => setTripType("oneway")}
              >{t(lang, "oneway")}</button>
            </div>
            <div className="form-row">
              <ACInput
                id="fl-from" label={t(lang, "from")} placeholder="London, Paris..."
                type="flight"
                value={flFrom} code={flFromCode}
                onChange={v => { setFlFrom(v); setFlFromCode(""); }}
                onPick={(label, code) => { setFlFrom(label); setFlFromCode(code); }}
                onSwitchToTrains={switchToTrainsFromFlights}
              />
              <ACInput
                id="fl-to" label={t(lang, "to")} placeholder="New York, Tokyo..."
                type="flight"
                value={flTo} code={flToCode}
                onChange={v => { setFlTo(v); setFlToCode(""); }}
                onPick={(label, code) => { setFlTo(label); setFlToCode(code); }}
                onSwitchToTrains={switchToTrainsFromFlights}
              />
            </div>
            <div className="form-row">
              <div className="form-field">
                <label>{t(lang, "date")}</label>
                <input type="date" value={flDate} onChange={e => setFlDate(e.target.value)} />
              </div>
              <div className="form-field" style={{ display: tripType === "oneway" ? "none" : "block" }}>
                <label>{t(lang, "return_date")}</label>
                <input type="date" value={flReturn} onChange={e => setFlReturn(e.target.value)} />
              </div>
            </div>
            <button className="search-btn" onClick={searchFlights}>{t(lang, "search")}</button>
          </div>

          {/* TRAINS — Omio widget */}
          <div className={"tab-form" + (tab === "trains" ? " active" : "")} style={{ padding: 0, minHeight: 80 }}>
            <div
              data-omio-widget="true"
              data-partner-id="voyagego"
              data-redirect="https://omio.sjv.io/c/7271483/861892/7385?u="
              data-layout="fluid"
              style={{ width: "100%" }}
              data-theme="blue"
            />
          </div>

          {/* BUSES — Omio widget */}
          <div className={"tab-form" + (tab === "buses" ? " active" : "")} style={{ padding: 0, minHeight: 80 }}>
            <div
              data-omio-widget="true"
              data-partner-id="voyagego"
              data-default-travel-mode="bus"
              data-redirect="https://omio.sjv.io/c/7271483/861892/7385?u="
              data-layout="fluid"
              style={{ width: "100%" }}
              data-theme="blue"
            />
          </div>

          {/* FERRY — Omio widget */}
          <div className={"tab-form" + (tab === "ferry" ? " active" : "")} style={{ padding: 0, minHeight: 80 }}>
            <div
              data-omio-widget="true"
              data-partner-id="voyagego"
              data-default-travel-mode="ferry"
              data-redirect="https://omio.sjv.io/c/7271483/861892/7385?u="
              data-layout="fluid"
              style={{ width: "100%" }}
              data-theme="blue"
            />
          </div>

          {/* HOTELS */}
          <div className={"tab-form" + (tab === "hotels" ? " active" : "")}>
            <div className="form-row">
              <ACInput
                id="ht-city" label={t(lang, "city")} placeholder="Paris, Rome, Tokyo..."
                type="city"
                value={htCity} code=""
                onChange={v => { setHtCity(v); setHtCityCode(""); }}
                onPick={(label, code) => { setHtCity(label); setHtCityCode(code); }}
              />
            </div>
            <div className="form-row">
              <div className="form-field">
                <label>{t(lang, "checkin")}</label>
                <input type="date" value={htIn} onChange={e => setHtIn(e.target.value)} />
              </div>
              <div className="form-field">
                <label>{t(lang, "checkout")}</label>
                <input type="date" value={htOut} onChange={e => setHtOut(e.target.value)} />
              </div>
            </div>
            <button className="search-btn" onClick={searchHotels}>{t(lang, "search")}</button>
          </div>

          {/* TOURS */}
          <div className={"tab-form" + (tab === "tours" ? " active" : "")}>
            <div className="form-row">
              <ACInput
                id="to-city" label={t(lang, "city")} placeholder="Paris, Barcelona, Kyoto..."
                type="city"
                value={toCity} code=""
                onChange={v => { setToCity(v); setToCityCode(""); }}
                onPick={(label, code) => { setToCity(label); setToCityCode(code); }}
              />
            </div>
            <button className="search-btn" onClick={searchTours}>{t(lang, "search")}</button>
          </div>

          {/* CARS */}
          <div className={"tab-form" + (tab === "cars" ? " active" : "")}>
            <div className="form-row">
              <ACInput
                id="ca-city" label={t(lang, "pickup")} placeholder="Lisbon, Barcelona..."
                type="city"
                value={caCity} code=""
                onChange={v => { setCaCity(v); setCaCityCode(""); }}
                onPick={(label, code) => { setCaCity(label); setCaCityCode(code); }}
              />
            </div>
            <button className="search-btn" onClick={searchCars}>{t(lang, "search")}</button>
          </div>
        </div>
      </section>

      {/* TRUST BAR */}
      <div className="trust-bar">
        <div className="trust-label">{t(lang, "partners")}</div>
        <div className="trust-logos">
          <span>Aviasales</span><span>Trip.com</span><span>Omio</span>
          <span>GetYourGuide</span><span>DiscoverCars</span><span>Hotellook</span>
        </div>
      </div>

      {/* DESTINATIONS */}
      <section className="section" id="destinations">
        <div className="section-head">
          <h2>{t(lang, "popular")}</h2>
          <a href="#" className="see-all">
            {t(lang, "see_all")} <svg className="icon"><use href="#i-arrow-right" /></svg>
          </a>
        </div>

        <DestCards
          deals={deals}
          curSym={curSym}
          rate={RATES[cur]}
          labels={{
            deal: t(lang, "deal"),
            special: t(lang, "special"),
            best: t(lang, "best"),
            direct: t(lang, "direct"),
            from: t(lang, "from_price"),
          }}
        />
      </section>

      {/* HOW IT WORKS */}
      <section className="section" id="how">
        <div className="section-head"><h2>{t(lang, "how_title")}</h2></div>
        <div className="how-grid">
          <div className="step-card">
            <div className="step-num">01</div>
            <div className="step-icon"><svg className="icon"><use href="#i-search" /></svg></div>
            <h3>{t(lang, "step1")}</h3>
            <p>{t(lang, "step1d")}</p>
          </div>
          <div className="step-card">
            <div className="step-num">02</div>
            <div className="step-icon"><svg className="icon"><use href="#i-credit-card" /></svg></div>
            <h3>{t(lang, "step2")}</h3>
            <p>{t(lang, "step2d")}</p>
          </div>
          <div className="step-card">
            <div className="step-num">03</div>
            <div className="step-icon"><svg className="icon"><use href="#i-plane-departure" /></svg></div>
            <h3>{t(lang, "step3")}</h3>
            <p>{t(lang, "step3d")}</p>
          </div>
        </div>
      </section>

      {/* FOOTER */}
      <footer>
        <div className="footer-grid">
          <div className="footer-brand">
            <div className="logo"><BrandLogo /></div>
            <p>{t(lang, "footer_desc")}</p>
          </div>
          <div className="footer-col">
            <h4>Product</h4>
            <a href="#">{t(lang, "ft_flights")}</a>
            <a href="#">{t(lang, "ft_hotels")}</a>
            <a href="#">{t(lang, "ft_tours")}</a>
            <a href="#">{t(lang, "ft_cars")}</a>
          </div>
          <div className="footer-col">
            <h4>Company</h4>
            <a href="#">{t(lang, "ft_about")}</a>
            <a href="#">{t(lang, "ft_partners")}</a>
            <a href="#">{t(lang, "ft_careers")}</a>
            <a href="#">{t(lang, "ft_contact")}</a>
          </div>
          <div className="footer-col">
            <h4>Legal</h4>
            <a href="#">{t(lang, "ft_terms")}</a>
            <a href="#">{t(lang, "ft_privacy")}</a>
            <a href="#">{t(lang, "ft_cookies")}</a>
          </div>
        </div>
        <div className="footer-bottom">
          <span>© 2026 VoyageGo. All rights reserved.</span>
          <span>voyagego.world</span>
        </div>
      </footer>

      {/* RESULTS OVERLAY */}
      {resultsOpen && (
        <div className="results-overlay show" onClick={e => { if (e.target === e.currentTarget) setResultsOpen(false); }}>
          <div className="results-box">
            <div className="results-header">
              <h3>{resultsTitle}</h3>
              <button className="results-close" onClick={() => setResultsOpen(false)}>×</button>
            </div>
            <div dangerouslySetInnerHTML={{ __html: resultsHTML }} />
          </div>
        </div>
      )}
    </>
  );
}
